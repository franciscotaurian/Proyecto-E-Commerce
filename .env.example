# E-Commerce Microservices Platform - Environment Variables Template
# Copy this file to .env and update with your actual values

# ========== SHARED CONFIGURATION ==========

# JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=your-secret-key-change-in-production

# MongoDB Connection
MONGO_URI=mongodb://mongodb:27017

# RabbitMQ Connection
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ========== SERVICE PORTS ==========

# Users Service
USERS_SERVICE_PORT=8081

# Products Service
PRODUCTS_SERVICE_PORT=8082

# Payments Service
PAYMENTS_SERVICE_PORT=8083

# ========== INTER-SERVICE URLS ==========

# Products Service URL (used by Payments Service)
PRODUCTS_SERVICE_URL=http://products-service:8080

# ========== EXTERNAL INTEGRATIONS ==========

# Mercado Pago Configuration
# Get your access token from: https://www.mercadopago.com/developers
MERCADOPAGO_ACCESS_TOKEN=TEST-ACCESS-TOKEN

# Envio Pack Configuration
# Get your API key from: https://enviopack.com
ENVIOPACK_API_KEY=TEST-API-KEY

# Webhook URL for Mercado Pago notifications
# In production, use your public domain URL
WEBHOOK_URL=http://payments-service:8080/api/v1/webhook/mercadopago

# ========== NOTIFICATIONS CONFIGURATION ==========

# Gmail SMTP Configuration (Required for Email Notifications)
# IMPORTANT: Use a Gmail App Password, not your regular Gmail password
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email sender display name
SMTP_FROM_NAME=E-Commerce Platform

# Email templates directory (relative to notifications-service root)
EMAIL_TEMPLATES_DIR=./templates

# ========== PRODUCTS SERVICE ==========

# Bleve Search Index Path
BLEVE_INDEX_PATH=/data/products.bleve
