# Build stage
FROM golang:1.21-alpine AS builder

WORKDIR /app

# Copy shared module first
COPY shared/ ./shared/

# Copy service code and set working directory
WORKDIR /app/users-service
COPY users-service/go.mod users-service/go.sum* ./
RUN go mod download

COPY users-service/ ./

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -o users-service ./cmd/main.go

# Runtime stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /root/

# Copy the binary from builder
COPY --from=builder /app/users-service/users-service .

EXPOSE 8080

CMD ["./users-service"]
